{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GUT: Run all tests",
      "type": "process",
      "command": "${config:godotTools.editorPath.godot4}",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--headless",
        "-s",
        "res://addons/gut/gut_cmdln.gd"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GUT: Run tests under res://test",
      "type": "process",
      "command": "${config:godotTools.editorPath.godot4}",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--headless",
        "-s",
        "res://addons/gut/gut_cmdln.gd",
        "--",
        "-gdir=res://test"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GUT: Run unit tests only",
      "type": "process",
      "command": "${config:godotTools.editorPath.godot4}",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--headless",
        "-s",
        "res://addons/gut/gut_cmdln.gd",
        "--",
        "-gdir=res://test/unit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GUT: Run integration tests only",
      "type": "process",
      "command": "${config:godotTools.editorPath.godot4}",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--headless",
        "-s",
        "res://addons/gut/gut_cmdln.gd",
        "--",
        "-gdir=res://test/integration"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GUT: Run all tests (Godot on PATH)",
      "type": "shell",
      "command": "godot --path \"${workspaceFolder}\" --headless -s res://addons/gut/gut_cmdln.gd",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
